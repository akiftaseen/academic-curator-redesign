<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.DeadlineDesk" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Primary Brand Color -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorOnPrimary">@color/on_primary</item>
        <item name="colorPrimaryContainer">@color/primary_container</item>
        <item name="colorOnPrimaryContainer">@color/on_primary_container</item>

        <!-- Tertiary Brand Color -->
        <item name="colorTertiary">@color/tertiary</item>
        <item name="colorOnTertiary">@color/on_tertiary</item>
        <item name="colorTertiaryContainer">@color/tertiary_container</item>
        <item name="colorOnTertiaryContainer">@color/on_tertiary_container</item>

        <!-- Surface Colors -->
        <item name="colorSecondaryContainer">@color/primary_fixed_dim</item>
        <item name="colorOnSecondaryContainer">@color/on_primary_fixed</item>
        <item name="android:colorBackground">@color/surface</item>
        <item name="colorOnBackground">@color/on_surface</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/on_surface</item>
        <item name="colorSurfaceVariant">@color/surface_variant</item>
        <item name="colorOnSurfaceVariant">@color/on_surface_variant</item>

        <!-- Navigation Bar -->
        <item name="android:navigationBarColor">@color/surface_container_lowest</item>
        <item name="android:windowLightNavigationBar">true</item>
        <item name="android:statusBarColor">@color/surface</item>
        <item name="android:windowLightStatusBar">true</item>
        
        <!-- Shape Styles -->
        <item name="shapeAppearanceSmallComponent">@style/ShapeAppearance.DeadlineDesk.Small</item>
        <item name="shapeAppearanceMediumComponent">@style/ShapeAppearance.DeadlineDesk.Medium</item>
        <item name="shapeAppearanceLargeComponent">@style/ShapeAppearance.DeadlineDesk.Large</item>
        
        <!-- Typography -->
        <item name="textAppearanceDisplayLarge">@style/TextAppearance.DeadlineDesk.DisplayLarge</item>
        <item name="textAppearanceHeadlineSmall">@style/TextAppearance.DeadlineDesk.HeadlineSmall</item>
        <item name="textAppearanceBodyLarge">@style/TextAppearance.DeadlineDesk.BodyLarge</item>
        <item name="textAppearanceLabelMedium">@style/TextAppearance.DeadlineDesk.LabelMedium</item>
    </style>

    <!-- Typography Styles -->
    <style name="TextAppearance.DeadlineDesk.DisplayLarge" parent="TextAppearance.Material3.DisplayLarge">
        <item name="fontFamily">@font/manrope</item>
        <item name="android:fontFamily">@font/manrope</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">56sp</item>
        <item name="android:letterSpacing">-0.02</item>
    </style>

    <style name="TextAppearance.DeadlineDesk.HeadlineSmall" parent="TextAppearance.Material3.HeadlineSmall">
        <item name="fontFamily">@font/manrope</item>
        <item name="android:fontFamily">@font/manrope</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">24sp</item>
    </style>

    <style name="TextAppearance.DeadlineDesk.BodyLarge" parent="TextAppearance.Material3.BodyLarge">
        <item name="fontFamily">@font/inter</item>
        <item name="android:fontFamily">@font/inter</item>
        <item name="android:textSize">16sp</item>
    </style>

    <style name="TextAppearance.DeadlineDesk.LabelMedium" parent="TextAppearance.Material3.LabelMedium">
        <item name="fontFamily">@font/inter</item>
        <item name="android:fontFamily">@font/inter</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">12sp</item>
    </style>

    <style name="ShapeAppearance.DeadlineDesk.Small" parent="ShapeAppearance.Material3.SmallComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">8dp</item>
    </style>

    <style name="ShapeAppearance.DeadlineDesk.Medium" parent="ShapeAppearance.Material3.MediumComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">12dp</item>
    </style>

    <style name="ShapeAppearance.DeadlineDesk.Large" parent="ShapeAppearance.Material3.LargeComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">24dp</item>
    </style>

    <style name="Widget.DeadlineDesk.ExposedDropdownMenu" parent="Widget.Material3.TextInputLayout.FilledBox.ExposedDropdownMenu">
        <item name="boxBackgroundColor">@color/surface_container_low</item>
        <item name="boxCornerRadiusTopStart">16dp</item>
        <item name="boxCornerRadiusTopEnd">16dp</item>
        <item name="boxCornerRadiusBottomStart">16dp</item>
        <item name="boxCornerRadiusBottomEnd">16dp</item>
        <item name="boxStrokeWidth">0dp</item>
        <item name="boxStrokeWidthFocused">0dp</item>
        <item name="endIconTint">@color/on_surface_variant</item>
    </style>

    <style name="Widget.DeadlineDesk.PrioritySegment" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:textAllCaps">false</item>
        <item name="android:textStyle">bold</item>
        <item name="fontFamily">@font/inter</item>
        <item name="android:fontFamily">@font/inter</item>
        <item name="android:textSize">13sp</item>
        <item name="strokeWidth">1dp</item>
        <item name="strokeColor">@color/outline_variant</item>
        <item name="backgroundTint">@color/priority_segment_background</item>
        <item name="android:textColor">@color/priority_segment_text</item>
        <item name="rippleColor">@color/surface_variant_80</item>
    </style>

    <style name="Widget.DeadlineDesk.PickerActionButton" parent="Widget.Material3.Button.TextButton.Dialog">
        <item name="android:textAllCaps">false</item>
        <item name="android:textStyle">bold</item>
        <item name="fontFamily">@font/inter</item>
        <item name="android:fontFamily">@font/inter</item>
    </style>

    <style name="ThemeOverlay.DeadlineDesk.MaterialCalendar" parent="ThemeOverlay.Material3.MaterialCalendar">
        <item name="colorSurface">@color/surface_container_lowest</item>
        <item name="colorOnSurface">@color/on_surface</item>
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryContainer">@color/primary_container</item>
        <item name="colorOnPrimaryContainer">@color/on_primary_container</item>
        <item name="buttonBarPositiveButtonStyle">@style/Widget.DeadlineDesk.PickerActionButton</item>
        <item name="buttonBarNegativeButtonStyle">@style/Widget.DeadlineDesk.PickerActionButton</item>
        <item name="shapeAppearanceMediumComponent">@style/ShapeAppearance.DeadlineDesk.Large</item>
    </style>

    <style name="ThemeOverlay.DeadlineDesk.MaterialTimePicker" parent="ThemeOverlay.Material3.MaterialTimePicker">
        <item name="colorSurface">@color/surface_container_lowest</item>
        <item name="colorOnSurface">@color/on_surface</item>
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryContainer">@color/primary_container</item>
        <item name="colorOnPrimaryContainer">@color/on_primary_container</item>
        <item name="buttonBarPositiveButtonStyle">@style/Widget.DeadlineDesk.PickerActionButton</item>
        <item name="buttonBarNegativeButtonStyle">@style/Widget.DeadlineDesk.PickerActionButton</item>
        <item name="shapeAppearanceMediumComponent">@style/ShapeAppearance.DeadlineDesk.Large</item>
    </style>

    <!-- Custom CalendarView Style -->
    <style name="Widget.DeadlineDesk.CalendarView" parent="android:Widget.CalendarView">
        <item name="android:selectedWeekBackgroundColor">@android:color/transparent</item>
        <item name="android:focusedMonthDateColor">@color/primary</item>
        <item name="android:unfocusedMonthDateColor">@color/outline_variant</item>
        <item name="android:weekSeparatorLineColor">@android:color/transparent</item>
        <item name="android:showWeekNumber">false</item>
    </style>

</resources>
