<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface">

    <FrameLayout
        android:id="@+id/fragment_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginBottom="92dp" />

    <ImageButton
        android:id="@+id/fab_add_deadline"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="104dp"
        android:background="@drawable/gradient_primary"
        android:contentDescription="@string/add_new_assignment"
        android:elevation="12dp"
        android:outlineAmbientShadowColor="@color/on_surface"
        android:outlineSpotShadowColor="@color/on_surface"
        android:src="@drawable/ic_add"
        app:tint="@color/on_primary"
        android:scaleType="center" />

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottom_navigation"
        android:layout_width="match_parent"
        android:layout_height="88dp"
        android:layout_gravity="bottom"
        android:background="@drawable/bg_bottom_nav_shell"
        app:elevation="10dp"
        app:itemActiveIndicatorStyle="@style/Widget.DeadlineDesk.BottomNavIndicator"
        app:itemIconTint="@color/nav_item_tint"
        app:itemTextColor="@color/nav_item_tint"
        app:itemRippleColor="@color/surface_variant"
        app:itemPaddingTop="10dp"
        app:itemPaddingBottom="12dp"
        app:labelVisibilityMode="labeled"
        app:menu="@menu/bottom_nav_menu" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
