<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="0dp"
    android:layout_marginVertical="8dp"
    app:cardBackgroundColor="@color/surface_container_lowest"
    app:cardCornerRadius="28dp"
    app:cardElevation="2dp"
    android:outlineAmbientShadowColor="@color/on_surface"
    android:outlineSpotShadowColor="@color/on_surface"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="18dp">

        <FrameLayout
            android:id="@+id/priority_indicator_container"
            android:layout_width="54dp"
            android:layout_height="54dp"
            android:background="@drawable/bg_priority_normal"
            android:layout_marginEnd="16dp">

            <ImageView
                android:id="@+id/iv_priority_icon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_tasks"
                android:contentDescription="@string/priority_icon_desc"
                app:tint="@color/primary" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tv_title"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:ellipsize="end"
                    android:fontFamily="@font/manrope"
                    android:maxLines="1"
                    android:textColor="@color/on_surface"
                    android:textSize="19sp"
                    android:textStyle="bold"
                    tools:text="Neural Networks Paper" />

                <TextView
                    android:id="@+id/tv_priority_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_label_normal"
                    android:fontFamily="@font/inter"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="4dp"
                    android:textAllCaps="true"
                    android:textColor="@color/outline"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    tools:text="NORMAL" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tv_module"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_label_normal"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="4dp"
                    android:fontFamily="@font/inter"
                    android:textColor="@color/on_surface"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    tools:text="CS402" />

                <View
                    android:layout_width="4dp"
                    android:layout_height="4dp"
                    android:layout_marginHorizontal="8dp"
                    android:background="@drawable/dot_separator" />

                <TextView
                    android:id="@+id/tv_due_time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/inter"
                    android:textColor="@color/outline"
                    android:textSize="14sp"
                    tools:text="23:59" />

                <TextView
                    android:id="@+id/tv_due_date"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:fontFamily="@font/inter"
                    android:textColor="@color/outline"
                    android:textSize="14sp"
                    android:visibility="gone"
                    tools:text="Oct 17" />
            </LinearLayout>
        </LinearLayout>

        <CheckBox
            android:id="@+id/cb_done"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:buttonTint="@color/primary" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
